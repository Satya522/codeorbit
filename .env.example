# Option A: use the Codex local bootstrap database (no password)
# DATABASE_URL=postgresql://postgres@127.0.0.1:5433/codeorbit

# Option B: use your own PostgreSQL and usually change only POSTGRES_PASSWORD
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=codeorbit
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password

REDIS_URL=redis://localhost:6379
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_PARTYKIT_HOST=127.0.0.1:1999
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://your-project.vercel.app
SESSION_COOKIE_NAME=codeorbit_session
SESSION_MAX_AGE_SECONDS=604800
AI_PROVIDER=gemini
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_MODEL=gemini-2.5-flash
DEEPSEEK_API_KEY=YOUR_DEEPSEEK_API_KEY
DEEPSEEK_MODEL=deepseek-chat
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
OPENAI_MODEL=gpt-4o-mini
GITHUB_TOKEN=YOUR_GITHUB_TOKEN
