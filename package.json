  "scripts": {
    "dev": "next dev --webpack",
    "postinstall": "prisma generate",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "check": "npm run prisma:validate && npm run typecheck && npm run lint && npm run build",
    "backend:bootstrap": "powershell -ExecutionPolicy Bypass -File scripts/bootstrap-backend.ps1",
    "partykit:dev": "partykit dev",
    "prisma:push": "prisma db push",
    "prisma:generate": "prisma generate",
    "prisma:validate": "prisma validate",
    "db:seed:practice": "node scripts/seed-practice-db.mjs"
  },
