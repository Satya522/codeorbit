{
  "name": "codeorbit",
  "version": "0.1.3",
  "description": "An integrated developer learning platform built with Next.js, Prisma, Clerk, PartyKit, and AI-assisted workflows.",
  "private": true,
  "license": "UNLICENSED",
  "author": "Satya522",
  "repository": {
    "type": "git",
