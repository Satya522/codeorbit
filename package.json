  "engines": {
    "node": "20.x",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "next dev --webpack",
    "postinstall": "prisma generate",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "check": "npm run prisma:validate && npm run test && npm run typecheck && npm run lint && npm run build",
    "backend:bootstrap": "powershell -ExecutionPolicy Bypass -File scripts/bootstrap-backend.ps1",
    "partykit:dev": "npx partykit@0.0.115 dev",
    "prisma:push": "prisma db push",
    "prisma:generate": "prisma generate",
    "prisma:validate": "prisma validate",
    "db:seed:practice": "node scripts/seed-practice-db.mjs"
  },
